github:
  access_token: SAMPLE
secret_scraper:
  - secret_provider: anthropic
    secret_type: anthropic_api_key
    secret_query_keyword: sk-ant-api03
    secret_regex_pattern: sk-ant-api03-[a-zA-Z0-9\-_]{90,}AA
  - secret_provider: anthropic
    secret_type: anthropic_admin_key
    secret_query_keyword: sk-ant-admin01
    secret_regex_pattern: sk-ant-admin01-[a-zA-Z0-9\-_]{90,}AA
  - secret_provider: openai
    secret_type: openai_api_key
    secret_query_keyword: sk-proj-
    secret_regex_pattern: sk-proj-[a-zA-Z0-9_-]{50,82}T3BlbkFJ[a-zA-Z0-9_-]{50,82}
  - secret_provider: openai
    secret_type: openai_service_account_key
    secret_query_keyword: sk-svcacct-
    secret_regex_pattern: sk-svcacct-[a-zA-Z0-9_-]{55,80}T3BlbkFJ[a-zA-Z0-9_-]{55,80}